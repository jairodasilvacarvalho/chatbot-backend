SET pitch_by_stage = '{
  &quot;abertura&quot;: &quot;Fala! 👋 Seja bem-vindo. Me conta rapidinho: você já conhece esse tipo de produto ou está pesquisando agora?&quot;,
  &quot;diagnostico&quot;: &quot;Antes de te indicar o melhor caminho, me diz: o que é mais importante pra você nesse produto — preço, qualidade ou praticidade?&quot;,
  &quot;oferta&quot;: &quot;Perfeito. Pelo que você me falou, esse kit encaixa exatamente no que você precisa. Ele resolve isso sem complicação.&quot;,
  &quot;fechamento&quot;: &quot;Se fizer sentido pra você, posso já te passar o link pra finalizar agora. Quer garantir o seu?&quot;
}'
WHERE tenant_id = 1
AND product_key = 'KIT_CHURRASCO_01';</sql><current_tab id="0"/></tab_sql></sqlb_project>
